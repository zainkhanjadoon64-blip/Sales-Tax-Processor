# Copy this file to .env.development.local and fill in real values.
# NEVER commit .env.development.local or any file containing real secrets.

# --- Database (Neon PostgreSQL) ---
# Required for production. SQLite is used as fallback in local dev only.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
POSTGRES_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# --- JWT ---
# Must be at least 32 random characters.
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# --- Vercel Blob storage ---
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- AI Gateway (optional) ---
AI_GATEWAY_API_KEY=

# --- Auth bypass ---
# MUST be false in any deployed environment. Only set to true for local dev.
DEV_AUTH_DISABLED=false

# --- CORS origins (comma-separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
